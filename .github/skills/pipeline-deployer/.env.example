# Example environment variables for pipeline deployment
# Copy this to .env and fill in your values

# Backend URL (choose your environment)
TEST_DEPLOYMENT_URL=https://dev.elitea.ai
# TEST_DEPLOYMENT_URL=https://stage.elitea.ai
# TEST_DEPLOYMENT_URL=https://next.elitea.ai

# Your API Bearer token
TEST_API_KEY=your_api_key_here

# Project ID (numeric)
TEST_PROJECT_ID=123

# Application ID (numeric, required for API endpoint)
TEST_APP=456

# Version ID (optional)
# If set, uses this version directly (TEST_APP still needed for endpoint)
# If not set, looks up "base" version or first version from TEST_APP
# TEST_VERSION=789
