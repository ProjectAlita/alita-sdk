# Example environment variables for pipeline deployment
# Copy this to .env in the project root and fill in your values
# Use --env /path/to/.env to specify a different file

# Backend URL (choose your environment)
TEST_DEPLOYMENT_URL=https://dev.elitea.ai
# TEST_DEPLOYMENT_URL=https://stage.elitea.ai
# TEST_DEPLOYMENT_URL=https://next.elitea.ai

# Your API Bearer token
TEST_API_KEY=your_api_key_here

# Project ID (numeric)
TEST_PROJECT_ID=123

# Application ID (numeric, always required)
TEST_APP=456

# Version ID (optional, update mode only)
# If set, updates this version directly. If not set, updates the active version.
# TEST_VERSION=789

# Git branch to commit the YAML file after successful deployment (optional)
# If set, the script will stage, commit, and push the YAML file to this branch.
# TEST_BRANCH=versions_backups
